# Environment Variables Template
# Copy this file to .env and fill in your actual values

#############
# FRONTEND  #
#############

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Agora (Video Calling)
NEXT_PUBLIC_AGORA_APP_ID=your_agora_app_id

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# PayHere (Payment Gateway)
NEXT_PUBLIC_PAYHERE_MERCHANT_ID=your_payhere_merchant_id

#############
# BACKEND   #
#############

# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://vetcare_user:vetcare_password@localhost:5432/vetcare_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this
JWT_REFRESH_EXPIRES_IN=30d

# File Storage (AWS S3 or Cloudinary)
# Option 1: AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=vetcare-uploads

# Option 2: Cloudinary (comment out if using S3)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Agora (Video Calling)
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# PayHere (Payment Gateway)
PAYHERE_MERCHANT_ID=your_merchant_id
PAYHERE_MERCHANT_SECRET=your_merchant_secret
PAYHERE_SANDBOX=true
PAYHERE_NOTIFY_URL=http://localhost:4000/api/v1/payments/webhook/payhere
PAYHERE_RETURN_URL=http://localhost:3000/payment/success
PAYHERE_CANCEL_URL=http://localhost:3000/payment/cancel

# Dialog SMS (Sri Lanka)
DIALOG_SMS_API_KEY=your_dialog_sms_api_key
DIALOG_SMS_SENDER_ID=VetCare
DIALOG_SMS_API_URL=https://sms.dialog.lk/api/v1

# Email Service (Resend or SendGrid)
# Option 1: Resend
RESEND_API_KEY=your_resend_api_key

# Option 2: SendGrid (comment out if using Resend)
# SENDGRID_API_KEY=your_sendgrid_api_key

EMAIL_FROM=noreply@vetcare.lk
EMAIL_FROM_NAME=VetCare Sri Lanka

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Facebook OAuth (Optional)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:4000/api/v1/auth/facebook/callback

# Monitoring & Error Tracking (Optional)
SENTRY_DSN=your_sentry_dsn

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
